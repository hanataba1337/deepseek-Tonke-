@echo off
chcp 65001 >nul
title DeepSeek Token Monitor

:: ============================================
:: DeepSeek Token Monitor Launcher
:: ============================================
:: Copy this file to start.bat and set your API key.
:: start.bat is gitignored so your key stays safe.
:: ============================================

set DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY_HERE

python "%~dp0main.py"
pause
